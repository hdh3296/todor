<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">할 일 수정</h2>
    <p class="mt-2 text-gray-600">할 일 내용을 변경할 수 있습니다</p>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with model: @todo, local: true, class: "space-y-6" do |form| %>
      <div>
        <%= form.label :title, "할 일", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :title, 
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg",
            autofocus: true %>
        <% if @todo.errors[:title].any? %>
          <p class="mt-2 text-sm text-red-600"><%= @todo.errors[:title].first %></p>
        <% end %>
      </div>

      <div>
        <%= form.label :completed, class: "flex items-center space-x-3 cursor-pointer" do %>
          <%= form.check_box :completed, class: "w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" %>
          <span class="text-sm font-medium text-gray-700">완료됨</span>
        <% end %>
      </div>

      <div class="flex justify-between">
        <%= link_to "취소", todos_path, 
            class: "px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors" %>
        
        <%= form.submit "수정하기", 
            class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
