<div class="space-y-6">
  <!-- 헤더 섹션 -->
  <div class="text-center">
    <h2 class="text-2xl font-bold text-gray-900">오늘의 할 일</h2>
    <p class="mt-2 text-gray-600">효율적으로 하루를 계획하고 관리하세요</p>
  </div>

  <!-- 새 할 일 추가 폼 -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with model: @todo, local: true, class: "space-y-4" do |form| %>
      <div>
        <%= form.text_field :title, 
            placeholder: "새로운 할 일을 입력하세요...", 
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg",
            autofocus: true %>
        <% if @todo.errors[:title].any? %>
          <p class="mt-2 text-sm text-red-600"><%= @todo.errors[:title].first %></p>
        <% end %>
      </div>
      
      <div class="flex justify-end">
        <%= form.submit "추가하기", 
            class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- 할 일 목록 -->
  <div class="space-y-3">
    <% if @todos.any? %>
      <div class="flex justify-between items-center">
        <h3 class="text-lg font-semibold text-gray-900">
          할 일 목록 (<%= @todos.count %>개)
        </h3>
        <div class="text-sm text-gray-500">
          완료: <%= @todos.completed.count %>개 / 미완료: <%= @todos.pending.count %>개
        </div>
      </div>

      <div class="space-y-2">
        <% @todos.each do |todo| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-3 flex-1">
                <%= link_to toggle_todo_path(todo), 
                    method: :patch, 
                    class: "flex-shrink-0" do %>
                  <div class="w-5 h-5 rounded border-2 flex items-center justify-center 
                              <%= todo.completed? ? 'bg-green-500 border-green-500' : 'border-gray-300 hover:border-green-400' %> 
                              transition-colors">
                    <% if todo.completed? %>
                      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
                
                <span class="<%= todo.completed? ? 'line-through text-gray-500' : 'text-gray-900' %> flex-1">
                  <%= todo.title %>
                </span>
                
                <span class="text-xs text-gray-400">
                  <%= time_ago_in_words(todo.created_at) %> 전
                </span>
              </div>
              
              <div class="flex items-center space-x-2 ml-4">
                <%= link_to edit_todo_path(todo), 
                    class: "text-gray-400 hover:text-blue-600 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
                
                <%= link_to todo_path(todo), 
                    method: :delete, 
                    data: { confirm: "정말 삭제하시겠습니까?" },
                    class: "text-gray-400 hover:text-red-600 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">할 일이 없습니다</h3>
        <p class="mt-2 text-gray-500">첫 번째 할 일을 추가해보세요!</p>
      </div>
    <% end %>
  </div>
</div>
